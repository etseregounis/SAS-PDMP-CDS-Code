data scored_bin;
   set rp.scored_KY;
   predicted = (prob >= 0.5);
run;

proc freq data=scored_bin;
   tables predicted*long_term / out=confmat nopercent norow nocol;
run;

data metrics;
   set confmat;
   if predicted=1 and long_term=1 then TP = count;
   else if predicted=1 and long_term=0 then FP = count;
   else if predicted=0 and long_term=0 then TN = count;
   else if predicted=0 and long_term=1 then FN = count;
run;

/* Step 2: Collapse to one row and compute metrics */
proc means data=metrics noprint;
   var TP FP TN FN;
   output out=totals sum=TP FP TN FN;
run;

/* Step 3: Calculate performance metrics */
data final_metrics;
   set totals;

   total = TP + FP + TN + FN;
   P = TP + FN;
   N = TN + FP;

   Accuracy    = (TP + TN) / total;
   Sensitivity = TP / (TP + FN);
   Specificity = TN / (TN + FP);
   PPV         = TP / (TP + FP);
   NPV         = TN / (TN + FN);
   Youden      = Sensitivity + Specificity - 1;
   NNP         = 1 / PPV;

   format Accuracy Sensitivity Specificity PPV NPV Youden NNP 8.3;
run;

proc print data=final_metrics noobs; run;

proc logistic data=rp.scored_KY;
   model long_term(event='1') = prob;
   roc 'Model' prob;
   roccontrast ;
run;

