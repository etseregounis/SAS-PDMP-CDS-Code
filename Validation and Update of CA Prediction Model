*** Update Intercept and Slope;;
* Determine validation calibration slope and intercept;;
data scored; set rp.scored_ky; lo=log(prob/(1-prob)); run;
proc logistic data=scored;
model long_term (event = '1') = lo / clparm=wald;
ods output ParameterEstimates=estis2;
run;
* Store intercept and calculate updated intercept and slope;;
 data _null_; set estis2;
if variable="Intercept" then call symput("iis2", estimate);
run; %put &=iis2;
data scored; set scored; lo_cal2=lo+(&iis2); pp_cal2=1/(1+exp(-lo_cal2)); run;
* Determine adjusted validation calibration intercept;;
proc logistic data=scored;
model long_term (event = '1') = lo_cal2 / clparm=wald;
run;

