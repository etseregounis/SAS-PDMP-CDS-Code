		r_q_maxday*r_q_maxday as rqmax_2, r_q_minday*r_q_minday as rqmin_2, r_q_v10_maxday*r_q_v10_maxday as rqv10max_2,
		log(q_auc) as log_qa, log(q_maxday+0.0001) as log_qmax, log(q_minday+0.0001) as log_qmin, 
		log(r_q_maxday+0.0001) as log_rqmax, log(r_q_minday+0.0001) as log_rqmin, log(r_q_v10_maxday+0.0001) as log_rqv10max,
		diffquan_tab30*diffquan_tab30 as diffquan_tab30_2, ratio_pill30*ratio_pill30 as ratio_pill30_2, 
		log(diffquan_tab30) as log_diffquan_tab30, log(ratio_pill30) as log_ratio_pill30,
	mme_auc*mme_auc as mmea_2, mme_diff_auc1*mme_diff_auc1 as mmed1_2, mme_maxday*mme_maxday as mmemax_2, mme_minday*mme_minday as mmemin_2,
		r_mme_maxday*r_mme_maxday as rmmemax_2, r_mme_minday*r_mme_minday as rmmemin_2, r_mme_v10_maxday*r_mme_v10_maxday as rmmev10max_2,
		log(mme_auc) as log_mmea, log(mme_maxday+0.0001) as log_mmemax, log(mme_minday+0.0001) as log_mmemin, 
		log(r_mme_maxday+0.0001) as log_rmmemax, log(r_mme_minday+0.0001) as log_rmmemin, log(r_mme_v10_maxday+0.0001) as log_rmmev10max,
		diffmme_tab30*diffmme_tab30 as diffmme_tab30_2, ratio_pill30_mme*ratio_pill30_mme as ratio_pill30_mme_2,
		log(diffmme_tab30) as log_diffmme_tab30, log(ratio_pill30_mme) as log_ratio_pill30_mme,
