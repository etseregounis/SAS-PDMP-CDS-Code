***** 1.1 Generate Base Dataset *****

** Isolate 30-day period post index opioid (one record per day post index per patient)
* Generate datafile with all Rxs given to any PONIs that appear in KASPER within 30 days of index Rx;;
* Dataset with all index days;;

proc sql;
create table rp.id_po as
select distinct clust_num, year(filled_at) as year, max(filled_at) as filled_at format mmddyy10.,
 	count(filled_at) as nrxs, count(distinct tab) as nrxtypes
from poni.first_opi where tab=1 and 2020 < calculated year < 2024
group by clust_num, year;
quit;
* Merge in all opioid pill prescriptions from index day to day 30;;
proc sql; create table p30_po (compress = yes) as
select *, naiveday+29 as day30 format mmddyy10.
from	(
		select b.clust_num, b.year, a.filled_at, a.days_supply, a.quantity, a.quantity/a.days_supply as quan_day, 
			   a.mme_eq, b.filled_at as naiveday
		from poni.all_opioids (where=(opioid=1 and tab=1)) a
		right join rp.id_po b on a.clust_num=b.clust_num and a.year=b.year
		) 
where filled_at ge naiveday and filled_at le (calculated day30);
quit;

** Create file with dose total for each day within 30 days post index date;;
*  Expand each rx out to individual days following index date;; 
data p30_po_days (compress = yes);					
set p30_po; where days_supply ne .;
do day=filled_at to (filled_at+days_supply-1);
	format day mmddyy10.;
	output;
end;
run;
* Collapse data to one record per patient-day following index date - with calculations;;
proc sql; create table p30_po_days2 (compress = yes) as
select clust_num, firstday, day, max(daysafter) as d, sum(mme_eq) as mme, sum(quantity) as quan, sum(quan_day) as qday
from	(
		select clust_num, day, naiveday as firstday, day-naiveday as daysafter, mme_eq, quantity, quan_day
		from p30_po_days where day le day30 and day ge naiveday
		)
group by clust_num, firstday, day;
quit;

** Impute zeros for days missing dose;;
* clust_nums from file;;
proc sql; create table pp as 					
select distinct clust_num, firstday
from p30_po_days2 group by clust_num, firstday;
quit;
* Generate "empty" days - days without opioid rx;;
data pp;										
set pp; by clust_num firstday;
do days=0 to 29; output; end;
run;
* Merge empty days into collapsed data file and replace missing mme/quantity with zeros;;
proc sql; create table rp.p30_po as			
select clust_num, days, firstday, case when m = . then 0 else m end as mme, case when q = . then 0 else q end as quan, 
	case when qd = . then 0 else qd end as quan_day
from 	(
		select b.clust_num, b.firstday, b.days as days, a.mme as m, a.quan as q, a.qday as qd
		from p30_po_days2 a full join pp b on a.clust_num=b.clust_num and a.firstday=b.firstday and a.d=b.days
		)
order by clust_num, firstday, days;
quit;

** Prepare file for analysis;;
* Id invididual PONI episodes;;
proc sql;
create table rp.p_eps as
select *, monotonic() as epi_id
from	(select distinct clust_num, naiveday as firstday, count(*) as n_rxs
		 from p30_po group by clust_num, naiveday
		);
quit;
* Prepare file for trajectory variable construction: center days -> generate second and third order day terms;;
proc sql; create table rp.analysis_pill (compress=yes) as 
select 	b.epi_id, a.clust_num, a.firstday, a.days-15 as dc, (a.days-15)*(a.days-15) as dc_2, (a.days-15)*(a.days-15)*(a.days-15) as dc_3, 
		a.days as d, a.days*a.days as d_2, a.days*a.days*a.days as d_3,
		a.mme, a.quan, a.quan_day
from rp.p30_po a left join rp.p_eps b on a.clust_num=b.clust_num and a.firstday=b.firstday;
quit;

* Delete datasets no longer needed;
proc datasets library=work; delete p30_po p30_po_days p30_po_days2 pp; run; quit;


***** 1.2 Characterize Trajectories Using Local Dose Polynomials *****

;
** Fit polynomials for Daily MME and Quantity;
proc sort data=rp.analysis_pill; by epi_id d; run;
proc reg data=rp.analysis_pill plots=none outest=poly_m_pill;
by epi_id; model mme = dc dc_2 dc_3 / noprint ;
run;
proc reg data=rp.analysis_pill plots=none outest=poly_q_pill;
by epi_id; model quan_day = dc dc_2 dc_3 / noprint ;
run;

** Calculate MME summary statistics;;
* Prep file for calculations;;
proc sql;							
create table pm as
select epi_id, (3*dc_3) as a, (2*dc_2) as b, dc as c,
	   dc_3 as b3, dc_2 as b2, dc as b1, intercept as b0
from poly_m_pill;
quit;
* MME: Polynomial statistic calculations;;
data calc_m; set pm;				
aucall	=((-12209/4)*b3)+((6119/3)*b2)+((-14.5)*b1)+(29*b0); 	/* area under the curve (all 29 days) */
auc_30	=(30*b0)+(2250*b2); 									/* area under the curve (all 30 days) */
auc1	=(-12656.25*b3)+(1125*b2)+(-112.5*b1)+(15*b0); 			/* area under the curve (0 to 15 days) */ 
auc2	=(9406*b3)+(2744*b2)+(98*b1)+(14*b0); 					/* area under the curve (15 to 29 days) */ 
auc3	=(-12500*b3)+((3250/3)*b2)-(100*b1)+(10*b0); 			/* area under the curve (0 to 10 days) */
auc4	=((250/3)*b2)+(10*b0); 									/* area under the curve (10 to 20 days) */
auc5	=(9447.75*b3)+((2869/3)*b2)+(85.5*b1)+(9*b0); 			/* area under the curve (20 to 29 days) */
auc2_30	=(12656.25*b3)+(1125*b2)+(112.5*b1)+(15*b0); 			/* area under the curve (15 to 30 days) */ 
auc5_30	=(12500*b3)+((3250/3)*b2)+(100*b1)+(10*b0); 			/* area under the curve (20 to 30 days) */

sq=(b*b)-(4*a*c);
if a ne 0 and sq ge 0 then p=((-b)+sqrt(sq))/(2*a); 			/* local polynomial critical point - plus - if outside range set to missing */
	if p gt 14 then p = .; if p lt -15 then p = .;
if a ne 0 and sq ge 0 then m=((-b)-sqrt(sq))/(2*a); 			/* local polynomial critical point - minus - if outside range set to missing */
	if m gt 14 then m = .; if m lt -15 then m = .;
phat_0=((-15)*(-15)*(-15)*b3)+((-15)*(-15)*b2)+((-15)*b1)+b0; 	/* predicted daily mme at day zero */
phat_30=((14)*(14)*(14)*b3)+((14)*(14)*b2)+((14)*b1)+b0; 		/* predicted daily mme at day thirty */
if p ne . then phat_plus=(p*p*p*b3)+(p*p*b2)+(p*b1)+b0; 		/* predicted daily mme at plus critical point */
if m ne . then phat_minus=(m*m*m*b3)+(m*m*b2)+(m*b1)+b0; 		/* predicted daily mme at minus critical point */
mn=min(of phat_0, phat_30, phat_plus, phat_minus); 				/* select minimum predicted mme */
	if mn=phat_0 then day_min=-15; 
	if mn=phat_30 then day_min=14;
	if mn=phat_plus then day_min=p; 
	if mn=phat_minus then day_min=m; 							/* determine on which day the minimum occurs */
mx=max(of phat_0, phat_30, phat_plus, phat_minus); 				/* select maximum predicted mme*/
	if mx=phat_0 then day_max=-15; 
	if mx=phat_30 then day_max=14;
	if mx=phat_plus then day_max=p; 
	if mx=phat_minus then day_max=m;							/* determine on which day the maximum occurs */

if b3 ne 0 then v10=((-b2)/(3*b3))+5;							/* day of critical point - if outside range set to missing */
	if v10 gt 14 then v10 = .; if v10 lt -6 then v10 = .;
v10_sq=30*b3; v10_lin=(-300*b3)+(20*b2); 
v10_cons=(1000*b3)-(100*b2)+(10*b1);
v10_0to10=((-6)*(-6)*v10_sq)+((-6)*v10_lin)+v10_cons;			/* change between days 0 and 10 */
v10_20to30=((14)*(14)*v10_sq)+((14)*v10_lin)+v10_cons;			/* change between days 20 and 30 */
if v10 ne . 
	then v10_crit=((v10)*(v10)*v10_sq)+((v10)*v10_lin)+v10_cons;/* change over 10 days prior to critical point */
vmx10=max(of v10_crit, v10_0to10, v10_20to30);					/* select maximum predicted 10-day change */
	if vmx10=v10_crit then day_v10max=v10;
	if vmx10=v10_0to10 then day_v10max=-6;
	if vmx10=v10_20to30 then day_v10max=14;						/* determine on which day the maximum change occurs */

v5=(75-(10*b2))/30;												/* day of critical point - if outside range set to missing */
	if v5 gt 14 then v5 = .; if v5 lt -11 then v5 = .;
v5_sq=15; v5_lin=(10*b2)-75; v5_cons=(-25*b2)+(5*b1)+125;
v5_0to5=((-11)*(-11)*(v5_sq))+((-11)*v5_lin)+v5_cons;			/* change between days 0 and 5 */
v5_25to30=((14)*(14)*(v5_sq))+((14)*v5_lin)+v5_cons;			/* change between days 25 and 30 */
if v5 ne . 
	then v5_crit=((v5)*(v5)*(v5_sq))+((v5)*v5_lin)+v5_cons;		/* change over 5 days prior to critical point */
vmx5=max(of v5_crit, v5_0to5, v5_25to30);						/* select maximum predicted 5-day change*/
	if vmx5=v5_crit then day_v5max=v5;
	if vmx5=v5_0to5 then day_v5max=-11;
	if vmx5=v5_25to30 then day_v5max=14;						/* determine on which day the maximum change occurs */
run;
* MME: Categorize and construct additional variables;;
proc sql; 							
create table mmestats as	
select 	epi_id, aucall as mme_auc, auc_30 as mme_aucold,
		auc1 as mme_auc0to15, auc2 as mme_auc15to30, auc3 as mme_auc0to10, auc4 as mme_auc10to20, auc5 as mme_auc20to30,
		auc2-auc1 as mme_diff_auc, auc4-auc3 as mme_diff_auc1, auc5-auc4 as mme_diff_auc2, 
		day_min+15 as mme_minday, day_max+15 as mme_maxday,
		case when day_max ge -15 and day_max lt -5 then 1
			 when day_max ge -5 and day_max lt 5 then 2
			 when day_max ge 5 and day_max le 14 then 3 else . end as mme_maxday_c,
		case when day_min ge -15 and day_min lt -5 then 1
			 when day_min ge -5 and day_min lt 5 then 2
			 when day_min ge 5 and day_min le 14 then 3 else . end as mme_minday_c,
		day_v5max+15 as mme_v5_maxday,
		case when day_v5max ge -15 and day_v5max lt -5 then 1
			 when day_v5max ge -5 and day_v5max lt 5 then 2
			 when day_v5max ge 5 and day_v5max le 14 then 3 else . end as mme_v5_maxday_c,
		day_v10max+15 as mme_v10_maxday,
		case when day_v10max ge -15 and day_v10max lt -5 then 1
			 when day_v10max ge -5 and day_v10max lt 5 then 2
			 when day_v10max ge 5 and day_v10max le 14 then 3 else . end as mme_v10_maxday_c
from calc_m;
quit;

