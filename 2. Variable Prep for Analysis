***** 1.3 Charactarize Trajectory Using Patient-level Residuals *****

1. Generate smoothed fixed effects model for the entire dataset - may want to include year term as well
2. Calculate predictive value for each day based on model fixed effect coefficients
3. Subtract patient MMEs/Quantities on each day by the predicted value derived from smoothed model
4. Fit GLM to residuals - use subject specific coefficients as trajectory covariates in RP Model
;;

** Generate dose residuals for each patient day post-index
* Use PROC GAMPL to output residuals;;
proc gampl data=rp.analysis_pill plots seed=6052020;
model mme = spline(dc_3 / maxknots=3) spline(dc_2 / maxknots=3) spline(dc / maxknots=3) 
	  / method=performance;
output out=res_m_pill resid;
id epi_id dc;
run; quit;
proc gampl data=rp.analysis_pill plots seed=6052020;
model quan_day = spline(dc_3 / maxknots=3) spline(dc_2 / maxknots=3) spline(dc / maxknots=3) 
	  / method=performance;
output out=res_q_pill resid;
id epi_id dc;
run; quit;
proc sql;
create table rp.analysis_pill2 (compress=yes) as 
select a.epi_id, a.dc, a.dc_2, a.dc_3, b.residual as res_m, c.residual as res_q
from rp.analysis_pill a left join 
	 res_m_pill b on a.epi_id=b.epi_id and a.dc=b.dc left join 
	 res_q_pill c on a.epi_id=c.epi_id and a.dc=c.dc;
quit;
* Use PROC REG to fit cubic polynomials to patient residuals;;
proc reg data=rp.analysis_pill2 plots=none outest=rc_reg_m_pill;
by epi_id; model res_m = dc dc_2 dc_3 / noprint ;
run;
proc reg data=rp.analysis_pill2 plots=none outest=rc_reg_q_pill;
by epi_id; model res_q = dc dc_2 dc_3 / noprint ;
run;
proc sql;
create table rc_reg_pill (compress=yes) as
select 	a.epi_id,
		a.intercept as reg_im, a.dc as reg_lm, a.dc_2 as reg_2m, a.dc_3 as reg_3m,
		b.intercept as reg_iq, b.dc as reg_lq, b.dc_2 as reg_2q, b.dc_3 as reg_3q
from rc_reg_m_pill a left join rc_reg_q_pill b on a.epi_id=b.epi_id;
quit;
* Merge files for analysis;
proc sql;
create table rp.tjvars_po (compress=yes drop=eid) as
select a.*, b.*
from rp.pstats_po  				 	  a left join 
	 rc_reg_pill (rename=(epi_id=eid)) b on a.epi_id=b.eid;
quit;

** Calculate MME RESIDUAL summary statistics;;
* Prep file for calculations;;
proc sql;							
create table rpm as
select epi_id, (3*reg_3m) as a, (2*reg_2m) as b, reg_lm as c,
	   reg_3m as b3, reg_2m as b2, reg_lm as b1, reg_im as b0
from rc_reg_pill;
quit;
* MME RESID: Polynomial statistic calculations;;
data calc_rm; set rpm;				
aucall	=((-12209/4)*b3)+((6119/3)*b2)+((-14.5)*b1)+(29*b0); 	/* area under the curve (all 29 days) */
auc_30	=(30*b0)+(2250*b2); 									/* area under the curve (all 30 days) */
