	case when ratio_erpill30 = 1 then 1 when ratio_erpill30 > 1 and ratio_erpill30 <= 2 then 2 when ratio_erpill30 > 2 then 3 
			   else . end as ratio_erpill30_c
from rp.a1_d30_po where 2020 < year < 2024;
