***** 3.1 Merge Individual Data Files *****;

** Merge indicator and summary dose files;;
data poni.ff; 
merge  d30 (keep = clust_num day0 day30 long_term age sexnum tab filled_at) q_days30 act_day30;
by clust_num day0;
year = year(day0);
ratio_pill30 = quan_pill/rx_pill;
ratio_pill30_mme = mme_pill/rx_pill;
lasa30 = n_lasa;

pharm30_opipill = pharm_opipill;
if pharm_opipill lt 2 then pharm30_opipill = 1;
if pharm_opipill ge 2 then pharm30_opipill = 2;

er30_opipill = er_opipill;
if er_opipill lt 2 then er30_opipill = 1;
if er_opipill ge 2 then er30_opipill = 2;

ratio_erpill30 = rx_pill/er_opipill;
if ratio_erpill30 lt 1 then ratio_erpill30 = 1;

array zz {*}  _numeric_;
do i = 1 to dim(zz);
if zz{i} = . then zz{i} = 0;
end;
drop i;

diffquan_tab30 = quan_tab30 - quan_tab0; 
diffmme_tab30 = mme_tab30 - mme_tab0; 

if filled_at = day0 then index=1; else index=0;
if tab = 1 and index = 1 then pillponi=1; else pillponi=0;
run;

** Merge new variables with trajectory variables;;
proc sql;
