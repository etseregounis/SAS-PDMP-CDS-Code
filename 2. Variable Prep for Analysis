	     when a.ndc in (50458082002, 50458082004, 50458083004, 50458084004) then "TAPENTADOL"
	     when a.ndc in (93005801, 93005805, 378415101, 378415105, 378415293, 378415393, 378415493, 378808801, 378808805, 904636561, 10370022111, 10370022211, 10370022311, 13811069130, 16714011106, 16714048101, 16714048102, 16714048103, 42571011901, 47335053183, 47335085983, 47335086083, 47335086183, 49884082111, 50458065960, 51079099120, 53746061701, 53746061705, 57664037708, 57664037713, 57664037718, 57664053713, 57664053718, 57664053788, 60505264405, 63739067110, 65162062710, 65162062711, 65162062750, 68084080811, 68180069706, 68180069806, 68180069906, 68382031901, 68382031910, 68382033401, 68382033405, 69543013610, 69543013611, 69543013650) then "TRAMADOL"
    	 when count(distinct b.drug) = 1 and ((year(filled_at) ge 2014 and upcase(b.drug) = "TRAMADOL") or upcase(b.drug) in ("HYDROCODONE" "CODEINE" "OXYCODONE" "HYDROMORPHONE" "MORPHINE")) then upcase(b.drug)
         when year(filled_at) lt 2014 and upcase(b.drug) = "TRAMADOL" then "OTHER"
         when count(distinct b.drug) ge 1 or upcase(b.drug) not in ("HYDROCODONE" "CODEINE" "TRAMADOL" "OXYCODONE", "HYDROMORPHONE", "MORPHINE") then "OTHER" 
	end as drug1
from poni.first_opi a
	left join raw.MME_OPIOID_UPDATED_VW2 b on a.ndc = b.ndc
where year(a.filled_at)
group by a.clust_num, a.filled_at
order by a.clust_num, day0;
quit;

** Identify active prescriptions on Day 30
--Rx Type:
	- Opioids
		- tab= pill form
		- liquid= liquid form
		- otherpatch= other form
		- lasap= long acting
	- Non-opioids
		- benzo= prescribed benzo
		- ocs= prescribed other controlled substance
--Active Rx Timing:
					Day 1						   Day 30
		(a, b, c)	  {------------------------------>
		(1, ., .)	  {------------------------------}
		(1, ., .)					   {-------------}
		(., 1, .)	  								 |
		(., 1, 1)	  								 {----->
		(., ., 1)							{-------------->	
;;
proc sql; 
create table act30_1 as
select distinct b.clust_num, a.day0, a.day30, 
	b.filled_at, b.filled_at + b.days_supply-1 as last_day format mmddyy10., 
	case when b.tab in (0 3) then 1 else 0 end as otherpatch,
	case when b.tab = 2 then 1 else 0 end as liquid,
	coalesce(b.benzo_ndc,0) as benzo, 
	coalesce(b.ocs, 0) as ocs,
	case when b.lasa = 1 and b.tab = 1 then 1 else 0 end as lasap, 
	case when (b.filled_at + b.days_supply) = a.day30 then 1 end as a,
	case when (b.filled_at = a.day30) then 1 end as b,
	case when b.filled_at <= a.day30 <= (b.filled_at + b.days_supply-1) then 1 end as c
from d30 a
inner join poni.all_opioids b  on a.clust_num = b.clust_num
where (((b.filled_at <= a.day30 <= (b.filled_at + b.days_supply-1)) or  /* a */ 
	  ((b.filled_at + b.days_supply) = a.day30) or /* b */
	  (b.filled_at = a.day30))) /* c */
order by clust_num, filled_at;
quit; 

** Merge into usable file;;
data act_day30;
merge act_benzo act_lasap act_ocs act_liquid act_otherpatch;
by clust_num day0;
run;

***** 2.3 Dose Summary Variables *****;

** Quantity and MME variables: day0 vs day30 - pills only;;
proc sql; 
create table q_days30 as
select distinct clust_num, day0, 
	sum(case when filled_at = day0 then quantity end) as quan_tab0,
	sum(case when filled_at <= day30 <= last_day then quantity end) as quan_tab30,
	sum(case when filled_at = day0 then mme end) as mme_tab0,
	sum(case when filled_at <= day30 <= last_day then mme end) as mme_tab30,  
	sum(quantity) as quan_pill, sum(mme) as mme_pill,
	count(*) as rx_pill,
	count(distinct dispensary_id) as pharm_opipill, count(distinct prescriber_id) as er_opipill 
from d30
where tab = 1
group by clust_num, day0
order by clust_num, day0;
quit;


